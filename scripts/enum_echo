"""enum_echo - subscribe to a ROS2 topic and print messages with enum decoding.

Usage::

    enum_echo /topic
    enum_echo /topic sensor_msgs/msg/NavSatStatus
    enum_echo /topic --count 5
    enum_echo /topic --no-enum

Enable tab completion (once per shell session or add to ~/.bashrc)::

    eval "$(register-python-argcomplete enum_echo)"

"""

import argparse
import sys
import time

import rclpy
from rclpy.node import Node
from rosidl_runtime_py import message_to_ordereddict
from rosidl_runtime_py.utilities import get_message

from ros2_msgs_enum_resolver.field_type_parser import FieldTypeParser
from ros2_msgs_enum_resolver.message_formatter import format_message


class _TopicCompleter:
    """Tab completer that queries live ROS2 topics via ``ros2 topic list``."""

    def __call__(self, prefix, **kwargs):
        try:
            import subprocess
            result = subprocess.run(
                ['ros2', 'topic', 'list'],
                capture_output=True,
                text=True,
                timeout=3.0,
            )
            topics = result.stdout.strip().splitlines()
            return [t for t in topics if t.startswith(prefix)]
        except Exception:
            return []


def _get_topic_type(node: Node, topic: str, timeout: float = 10.0) -> str:
    """Wait until the topic appears in the graph and return its type string."""
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        for name, types in node.get_topic_names_and_types():
            if name == topic and types:
                return types[0]
        rclpy.spin_once(node, timeout_sec=0.2)
    raise RuntimeError(
        f"Topic '{topic}' not found after {timeout:.0f}s. "
        f"Is the publisher running? You can also pass the type explicitly."
    )


def _ros2_type_to_interface(ros2_type: str) -> str:
    """Normalise a ROS2 type string to pkg/msg/Name form."""
    parts = ros2_type.split('/')
    if len(parts) == 3:
        return ros2_type
    if len(parts) == 2:
        return f'{parts[0]}/msg/{parts[1]}'
    return ros2_type


class EnumEchoNode(Node):
    """Subscribes to a topic and prints messages with optional enum decoding."""

    def __init__(
        self,
        topic: str,
        msg_type_str: str,
        count: int,
        enum_enabled: bool,
    ) -> None:
        super().__init__('enum_echo')
        self._interface_type = _ros2_type_to_interface(msg_type_str)
        self._count = count
        self._received = 0
        self._enum_enabled = enum_enabled

        msg_class = get_message(msg_type_str)
        self._sub = self.create_subscription(
            msg_class, topic, self._callback, 10,
        )

    def _callback(self, msg: object) -> None:
        """Handle one incoming message."""
        msg_dict = message_to_ordereddict(msg)
        formatted = format_message(
            msg_dict,
            self._interface_type,
            indent=0,
            enabled=self._enum_enabled,
        )
        print(formatted)
        print('---')
        self._received += 1

    @property
    def done(self) -> bool:
        """Return True when the requested message count has been received."""
        return 0 < self._count <= self._received


def main() -> int:
    """Entry point for the enum_echo script."""
    parser = argparse.ArgumentParser(
        description='Subscribe to a ROS2 topic and print messages with enum decoding.',
    )

    topic_arg = parser.add_argument(
        'topic',
        help='Topic name, e.g. /my_topic',
    )
    topic_arg.completer = _TopicCompleter()

    parser.add_argument(
        'msg_type', nargs='?', default=None,
        help='Message type (optional). If omitted, detected automatically.',
    )
    parser.add_argument(
        '--count', '-n', type=int, default=0, metavar='N',
        help='Stop after N messages (default: run until Ctrl-C).',
    )
    parser.add_argument(
        '--no-enum', action='store_true',
        help='Disable enum decoding (plain echo mode).',
    )
    parser.add_argument(
        '--wait-timeout', type=float, default=10.0, metavar='SECS',
        help='Seconds to wait for topic type auto-detection (default: 10).',
    )

    # argcomplete.autocomplete() MUST be called before parse_args().
    # When the user presses Tab, argcomplete intercepts here, calls
    # _TopicCompleter and exits without ever reaching rclpy.init().
    import argcomplete
    argcomplete.autocomplete(parser)

    args = parser.parse_args()

    rclpy.init()
    node = None

    try:
        if args.msg_type is None:
            detect_node = rclpy.create_node('enum_echo_detect')
            try:
                msg_type_str = _get_topic_type(
                    detect_node, args.topic, args.wait_timeout
                )
            finally:
                detect_node.destroy_node()
        else:
            msg_type_str = args.msg_type

        if not args.no_enum:
            FieldTypeParser.get_fields(_ros2_type_to_interface(msg_type_str))

        node = EnumEchoNode(
            topic=args.topic,
            msg_type_str=msg_type_str,
            count=args.count,
            enum_enabled=not args.no_enum,
        )

        print(
            f"Subscribing to {args.topic} [{msg_type_str}] ... "
            f"({'enum decoding ON' if not args.no_enum else 'plain mode'})"
        )
        print()

        if args.count > 0:
            while rclpy.ok() and not node.done:
                rclpy.spin_once(node, timeout_sec=0.1)
        else:
            rclpy.spin(node)

    except KeyboardInterrupt:
        pass
    except RuntimeError as exc:
        print(f'ERROR: {exc}', file=sys.stderr)
        return 1
    finally:
        if node is not None:
            node.destroy_node()
        try:
            rclpy.shutdown()
        except Exception:
            pass

    return 0


if __name__ == '__main__':
    sys.exit(main())